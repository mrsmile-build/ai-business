.ok{background:#d1fae5;color:#065f46;}
.wait{background:#fef3c7;color:#92400e;}
.ai{color:#16a34a;margin-top:8px;}
</style>
  </div>

  <!-- STATS -->
  <div class="grid">
    <div class="card">
      <div>Total Leads</div>
      <div class="stat" id="total">0</div>
    </div>

    <div class="card">
      <div>Status</div>
      <div class="stat" id="status">Idle</div>
    </div>
  </div>

  <!-- LEADS -->
  <div id="leads"></div>

</div>

